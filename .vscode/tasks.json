{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ESLint: Lint Project",
      "type": "shell",
      "command": "npx eslint .",
      "problemMatcher": "$eslint-stylish",
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
